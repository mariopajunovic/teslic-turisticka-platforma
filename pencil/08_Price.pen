                      "type": "text",
                      "id": "q2NNVn",
                      "fill": "$primary-darker",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Med ne možeš požurivati. Ili imaš dobru pašu i dobre pčele, ili nemaš med.",
                      "lineHeight": 1.45,
                      "fontFamily": "$font-heading",
                      "fontSize": 18,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "bhSCS",
                  "fill": "$heading",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Jutro u pčelinjaku",
                  "lineHeight": 1.3,
                  "fontFamily": "$font-heading",
                  "fontSize": 19,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "b9Mdl",
                  "fill": "$text",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Stigli smo u zoru, kada su pčele najmirnije. Marko polako otvara košnice i pokazuje saće prepuno meda. Svaki pokret je odmjeren jer nagle kretnje uznemiravaju roj.",
                  "lineHeight": 1.7,
                  "fontFamily": "$font-sans",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "Quxr6",
                  "name": "SlikaUTekstu",
